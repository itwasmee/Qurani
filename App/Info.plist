<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>LSUIElement</key><true/>
  <key>CFBundleName</key><string>Qurani</string>
  <!-- Standard identity keys, expanded from build settings at build time. Without these the
       built app had NO bundle id or version — Bundle.main.bundleIdentifier was nil, which the
       in-app updater needs for both the version comparison and validating a downloaded build. -->
  <key>CFBundleIdentifier</key><string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleExecutable</key><string>$(EXECUTABLE_NAME)</string>
  <key>CFBundlePackageType</key><string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
  <key>CFBundleInfoDictionaryVersion</key><string>6.0</string>
  <key>CFBundleShortVersionString</key><string>$(MARKETING_VERSION)</string>
  <key>CFBundleVersion</key><string>$(CURRENT_PROJECT_VERSION)</string>
  <key>ATSApplicationFontsPath</key><string>.</string>
  <key>NSAppTransportSecurity</key>
  <dict>
    <!-- Several world Qur'an radios are http-only (bare-IP / Mixlr / Shoutcast). This allows
         AVFoundation media loads over http without enumerating every host. -->
    <key>NSAllowsArbitraryLoadsForMedia</key><true/>
    <key>NSExceptionDomains</key>
    <dict>
      <!-- radiojar 302s the Egypt feed to insecure HTTP; qurango icecast is HTTP.
           The https Akamai / kwikmotion / mp3quran feeds need no exception. -->
      <key>radiojar.com</key>
      <dict>
        <key>NSExceptionAllowsInsecureHTTPLoads</key><true/>
        <key>NSIncludesSubdomains</key><true/>
      </dict>
      <key>qurango.net</key>
      <dict>
        <key>NSExceptionAllowsInsecureHTTPLoads</key><true/>
        <key>NSIncludesSubdomains</key><true/>
      </dict>
    </dict>
  </dict>
</dict></plist>
